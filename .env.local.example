# Copy to .env.local and fill in. .env.local is gitignored.

# --- Supabase (required) ---
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Keep this SECRET. Used only by seed/enrichment scripts and admin routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Admin gate (Phase 5) ---
# Comma-separated emails allowed to reach /admin and change request status.
ADMIN_EMAILS=ryan@dupely.io

# --- Google Maps (Phase 3, optional until you have a key) ---
# Server-side key for Places API (Text Search + Details). Restrict by API.
GOOGLE_MAPS_API_KEY=
# Public key used only for the Maps Embed iframe on venue pages.
# Restrict this one by HTTP referrer. May be the same project, different key.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# --- Jack-voice blurbs (Phase 4, optional) ---
# Anthropic API key for scripts/blurbs.ts. Without it, seeded fallback blurbs
# (derived from the top mention) are used.
ANTHROPIC_API_KEY=
